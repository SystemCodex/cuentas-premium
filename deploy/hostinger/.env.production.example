# Copia este archivo como .env en Hostinger y completa los valores reales.
# No subas este archivo con secretos reales a repositorios publicos.

NODE_ENV="production"
PORT=3000

# PostgreSQL administrado o base PostgreSQL del VPS.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
DATABASE_USE_POOLER="true"

# Minimo 32 caracteres. Deben mantenerse estables.
JWT_SECRET="CAMBIA_ESTE_SECRETO_LARGO_DE_32_CARACTERES_O_MAS"
APP_ENCRYPTION_KEY="CAMBIA_ESTA_CLAVE_ESTABLE_DE_32_CARACTERES_O_MAS"

# Dominio publico del frontend/backend.
# Si sirves todo desde la misma app Node, usa tu dominio principal.
CORS_ORIGIN="https://tudominio.com"
FRONTEND_ORIGIN="https://tudominio.com"
VITE_API_URL=""

# WhatsApp Bridge interno.
WHATSAPP_BRIDGE_ENABLED="true"
WHATSAPP_BRIDGE_HARD_DISABLED="false"
WHATSAPP_BRIDGE_AUTOSTART="true"
WHATSAPP_BRIDGE_MODE="baileys"
WHATSAPP_RECONNECT_DELAY_SECONDS="10"
WHATSAPP_BAILEYS_LOG_LEVEL="silent"
WHATSAPP_MAX_ATTEMPTS="3"
WHATSAPP_RETRY_DELAY_SECONDS="30"
WHATSAPP_EMAIL_FALLBACK_SECONDS="60"

# Numero que recibira avisos del sistema. Usa formato internacional.
ADMIN_NOTIFICATION_PHONE="573001112233"
ADMIN_NOTIFICATION_EMAIL=""

# Correo de respaldo opcional.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Entrada automatica de WhatsApp: fase 2, mantener apagado para produccion.
WHATSAPP_INBOUND_ENABLED="false"
WHATSAPP_ALLOWED_INBOUND_NUMBERS=""
WHATSAPP_ADMIN_PHONE=""
WHATSAPP_RECEIVER_MODE="delivery_inbound"
AUTO_DELIVERY_CONFIDENCE_THRESHOLD="85"

# Seed/creacion manual inicial.
ADMIN_EMAIL=""
ADMIN_NAME="Administrador Centro Digital"
ADMIN_CODE=""
CLIENT_EMAIL=""
CLIENT_NAME="Cliente Centro Digital"
CLIENT_CODE=""
CLIENT_PHONE=""
PROVIDER_EMAIL=""
PROVIDER_NAME="Proveedor Centro Digital"
PROVIDER_CODE=""
PROVIDER_PHONE=""
PROVIDER_NEQUI_NUMBER=""
PROVIDER_DOCUMENT=""
