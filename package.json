{
  "name": "premium-accounts-platform",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite --host 0.0.0.0",
    "postinstall": "prisma generate",
    "build": "prisma generate && prisma migrate deploy && tsx prisma/seed.ts && tsx scripts/bootstrap-production.ts && vite build && tsc -p tsconfig.server.json",
    "build:server": "tsc -p tsconfig.server.json",
    "build:all": "prisma generate && vite build && tsc -p tsconfig.server.json",
    "start": "node server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:demo": "tsx prisma/seed-demo.ts",
    "db:production": "npm run db:deploy && npm run db:generate && npm run db:seed",
    "create-admin": "tsx scripts/create-admin.ts",
    "create-provider": "tsx scripts/create-provider.ts",
    "bootstrap:production": "tsx scripts/bootstrap-production.ts",
    "clear:operational": "tsx scripts/clear-operational-data.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.1",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.10",
    "prisma": "^6.19.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "whatsapp-web.js": "^1.34.7",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
